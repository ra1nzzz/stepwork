{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "STEPWORK",
  "version": "0.1.0",
  "identifier": "com.stepwork.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "STEPWORK",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 700,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc:; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [],
    "externalBin": [],
    "webviewInstallMode": "embedBootstrapper"
  }
}
