{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stepwork.dev/schemas/job-state.enum.json",
  "title": "JobState",
  "description": "STEPWORK Job primary state machine (SYSTEM_SPEC §10.1). Nine top-level states.",
  "type": "string",
  "enum": [
    "PENDING",
    "READY",
    "RUNNING",
    "WAITING_EXTERNAL",
    "WAITING_USER",
    "RETRY_SCHEDULED",
    "COMPLETED",
    "FAILED_FINAL",
    "CANCELLED"
  ]
}
